<%- include('templates/header') %>
<section class="py-8 widescreen:section-min-height tallscreen:section-min-height my-12 scroll-mt-16 p-6">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row -mx-4">
      <div class="w-full lg:w-[55%] px-4">
        <div class="rounded-lg mb-6">
          <%- include('templates/products/carousel') %>
        </div>
      </div>
      <div class="w-full lg:w-[45%] px-4">
        <h1 class="text-4xl font-bold text-gray-800 dark:text-white mb-2"><%- product.branded ? site.company + '&trade; ' : '' %><%= getTranslatedProductTitle(product, language) %></h1>
        <div class="mb-2">
        <% if (product.star_rating) { %>
          <%- include('templates/products/star_rating_precise') %>
        <% } %>
          <p class="mt-3">
            <% if (product.compare_at_price) { %>
              <span class="line-through text-lg text-red-500 mr-1 productOldPrice" data-pk="<%- product.pk %>"><%= formatCurrency(getProductCompareAtPrice(product)) %></span>
            <% } %>
            <span class="font-bold text-xl productPrice" data-pk="<%- product.pk %>"><%= formatCurrency(getProductPrice(product)) %></span>
            <% if (product.out_of_stock) { %>
              <span class="bg-zinc-400 text-gray-800 rounded-full px-3 py-0.5 ml-1 text-sm">Out of Stock</span>
            <% } else if (product.sale) { %>
              <span class="bg-red-700 text-white rounded-full px-3 py-0.5 ml-1">Sale</span>
            <% } %>
          </p>
          <p class="text-sm mt-1 text-gray-500">Tax included. Free <a href="/policies/shipping-policy.html" class="underline" target="_blank">Shipping</a>.</p>
        </div>
        <% if (product.sizes) { %>
          <%- include('templates/products/select_size') %>
        <% } %>
        <% if (product.colors && product.use_color_names_in_select) { %>
          <%- include('templates/products/select_color') %>
        <% } %>
        <% if (product.colors && !product.use_color_names_in_select) { %>
          <%- include('templates/products/select_color_swatches') %>
        <% } %>
        <div class="mb-4">
          <label for="quantity-input" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Quantity:</label>
          <div class="relative flex items-center max-w-32">
            <button type="button" onclick="decrementProduct('<%- product.pk %>')"
              class="cursor-pointer bg-gray-100 dark:bg-gray-700 dark:hover:bg-gray-600 dark:border-gray-600 hover:bg-gray-200 border border-gray-300 rounded-s-lg px-3 h-12 focus:ring-gray-100 dark:focus:ring-gray-700 focus:ring-2 focus:outline-none">
              <svg class="w-3 h-3 text-gray-900 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 2">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h16"/>
              </svg>
            </button>
            <input type="text" id="productQty-<%- product.pk %>" onchange="validateAndSetProductQuntity('<%- product.pk %>')" aria-describedby="helperTextExpl"
              class="bg-gray-50 border-x-0 border-gray-300 h-12 text-center text-gray-900 text-sm focus:ring-blue-500 focus:border-blue-500 block w-12 py-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
              placeholder="1" value="1" required />
            <button type="button" onclick="incrementProduct('<%- product.pk %>')"
              class="cursor-pointer bg-gray-100 dark:bg-gray-700 dark:hover:bg-gray-600 dark:border-gray-600 hover:bg-gray-200 border border-gray-300 rounded-e-lg px-3 h-12 focus:ring-gray-100 dark:focus:ring-gray-700 focus:ring-2 focus:outline-none">
              <svg class="w-3 h-3 text-gray-900 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 1v16M1 9h16"/>
              </svg>
            </button>
          </div>
          <% if (!product.disabled && !product.out_of_stock) { %>
            <p class="urgencyMsg mt-2 text-sm text-gray-500 dark:text-gray-400"></p>
          <% } %>
        </div>
        <%- include('templates/products/add_to_cart_buttons') %>
        <div class="w-full mb-4">
          <div class="pr-4">
            <img class="mx-auto rounded-sm" src="/img/paymentcard.png" alt="Payment card methods" />
          </div>
        </div>
        <%- include('templates/products/paypal_button') %>
        <hr class="divider">
        <div class="mt-4">
          <%- getTranslatedProductDescription(product, language) %>
        </div>
        <%- include('templates/products/add_to_cart_buttons') %>
      </div>
    </div>
  </div>
</section>
<%- serializeProduct(product) %>
<%- include('templates/products/related_products') %>
<%- include('templates/products/reviews') %>
<%- include('templates/footer') %>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    initCarouselSwipe('<%- product.pk %>');
  });
</script>
