    </main>
    <footer id="footer" class="<%- site.mainBgColor %> text-xl text-white">
      <section class="mx-auto flex max-w-4xl flex-col p-4 sm:flex-row sm:justify-between">
        <address>
          <h2><%- site.company %>&trade;</h2>
          Monday–Friday<br />
          9am–5pm EST<br />
          E-mail:
          <a href="mailto:<%= site.email %>"><%= site.email %></a>
        </address>
        <nav class="hidden flex-col gap-2 md:flex" aria-label="footer">
          <a href="<%- localizeUrl('/#products') %>" class="hover:opacity-90"><%= t('nav.shop') %></a>
        <% if (hasTestimonials) { %>
          <a href="/#testimonials" class="hover:opacity-90"><%= t('nav.testimonials') %></a>
        <% } %>
        <% if (hasBlogs) { %>
          <a href="/blogs.html" class="hover:opacity-90"><%= t('nav.blogs') %></a>
        <% } %>
          <a href="/#contact" class="hover:opacity-90"><%= t('nav.contact') %></a>
        </nav>
        <nav class="hidden flex-col gap-2 md:flex" aria-label="footer">
          <a href="<%- localizeUrl('/policies/privacy-policy.html') %>" class="hover:opacity-90"><%= t('nav.privacy_policy') %></a>
          <a href="<%- localizeUrl('/policies/refund-policy.html') %>" class="hover:opacity-90"><%= t('nav.refund_policy') %></a>
          <a href="<%- localizeUrl('/policies/shipping-policy.html') %>" class="hover:opacity-90"><%= t('nav.shipping_policy') %></a>
          <a href="<%- localizeUrl('/policies/terms-of-service.html') %>" class="hover:opacity-90"><%= t('nav.terms_of_service') %></a>
        </nav>
        <div class="flex flex-col sm:gap-2">
          <p class="text-right">Copyright &copy; <span id="year">2026</span></p>
          <p class="text-right">All Rights Reserved</p>
          <script>
            const year = document.getElementById('year');
            const thisYear = new Date().getFullYear();
            year.setAttribute('datetime', thisYear);
            year.textContent = thisYear;
          </script>
          <%- include('country_select') %>
          <%- include('currency_select') %>
          <%- include('language_select') %>
          <%- include('light_dark_mode_theme_toggle_button') %>
          <%- include('light_dark_mode_theme_toggle_script') %>
        </div>
      </section>
      <%- include('chat/chat_button') %>
    </footer>
  </body>
</html>
